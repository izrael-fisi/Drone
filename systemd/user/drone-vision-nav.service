[Unit]
Description=Drone Vision Navigation Host Runtime
Documentation=%h/Drone/docs/raspberry-pi-setup.md
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/Drone
EnvironmentFile=-%h/Drone/config/pi/vision-nav.env
ExecStartPre=%h/Drone/scripts/pi/validate_terrain_bundle.sh
ExecStart=%h/Drone/scripts/pi/run_terrain_nav_loop.sh
Restart=on-failure
RestartSec=5
TimeoutStartSec=120

[Install]
WantedBy=default.target
