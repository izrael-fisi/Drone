# Copy to config/pi/vision-nav.env and edit on the Raspberry Pi if needed.

# Host camera/matching runtime.
# Leave these commented to use the script defaults under your current $HOME.
# Uncomment and edit if you want service-specific overrides.
# Current default storage is the onboard microSD via $HOME paths. If you later
# mount a USB SSD, point bundle/output paths at that mount.
# VISION_NAV_BUNDLE=/home/pi/drone-data/map_bundles/mission_bundle
# VISION_NAV_OUTPUT_DIR=/home/pi/DroneTransfer/outgoing/terrain-match
# VISION_NAV_COUNT=0
# VISION_NAV_INTERVAL_S=1.0
# VISION_NAV_WIDTH=1456
# VISION_NAV_HEIGHT=1088
# VISION_NAV_TIMEOUT_MS=1000
# VISION_NAV_CAMERA_CALIBRATION=/home/pi/Drone/config/camera/down_camera.yaml
# VISION_NAV_TERRAIN_MAX_CANDIDATES=64
# VISION_NAV_TERRAIN_SEARCH_RADIUS_M=80.0
# VISION_NAV_RUNTIME_PROFILE=pi5_full
# VISION_NAV_CAMERA_PROFILE=rgb_global_shutter
# VISION_NAV_MODULE_WEIGHT_G=
# VISION_NAV_ESTIMATED_BOM_USD=
# VISION_NAV_CAMERA_COST_USD=
# VISION_NAV_SENSOR_COMPLIANCE_NOTES=
# VISION_NAV_MOUNT_VIBRATION_NOTES=
# VISION_NAV_REQUIRE_CALIBRATION=1
# VISION_NAV_REQUIRE_FEATURES=0
# VISION_NAV_REQUIRE_CHECKSUMS=0

# Optional barometer support is automatic when MAVLink ALTITUDE or pressure
# telemetry is available. Replay logs may include a "barometer" object with
# altitude_m, relative_altitude_m, or pressure_hpa.

# Optional PX4 MAVLink output. Leave disabled during camera/map validation.
# When enabled, accepted local map measurements are sent as VISION_POSITION_ESTIMATE.
# VISION_NAV_MAVLINK_ENDPOINT=serial:/dev/ttyAMA0:921600
# VISION_NAV_MAVLINK_EV_DELAY_MS=50
# VISION_NAV_MAVLINK_SOURCE_SYSTEM=42
# VISION_NAV_MAVLINK_SOURCE_COMPONENT=197
# VISION_NAV_POSITION_UDP_TARGET=255.255.255.255:17660

# Replay/log helper defaults.
# VISION_NAV_TERRAIN_REPLAY_LOG=/home/pi/DroneTransfer/outgoing/terrain-match/terrain_matches.jsonl
# VISION_NAV_REPLAY_OUTPUT_DIR=/home/pi/DroneTransfer/outgoing/terrain-replay
# VISION_NAV_RUNTIME_LOG=/home/pi/DroneTransfer/outgoing/terrain-match/terrain_matches.jsonl
# VISION_NAV_REPLAY_LOG=/home/pi/DroneTransfer/outgoing/terrain-replay/terrain_replay_matches.jsonl

# Docker container paths.
VISION_NAV_LOG_DIR=/logs
VISION_NAV_MAP_DIR=/maps
VISION_NAV_CONFIG_DIR=/config
VISION_NAV_CAMERA_CONFIG=/config/camera/down_camera.yaml
VISION_NAV_EXTRINSICS_CONFIG=/config/camera/camera_to_body.yaml
